<?xml version="1.0"?>
<robot name="ur5e">
  <!--
    UR5e – plain URDF (no xacro)
    Kinematic parameters from ros-industrial/universal_robot
    noetic-devel: ur_description/config/ur5e/default_kinematics.yaml

    All 6 revolute joints rotate around their local Z axis.
    Joint origins are taken directly from default_kinematics.yaml;
    shoulder_offset / elbow_offset are visual geometry offsets only.

    Joint limits (±360° for wrist/shoulder, ±180° for elbow) from joint_limits.yaml.
  -->

  <!-- ======================================================== -->
  <!-- Links                                                      -->
  <!-- ======================================================== -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.10"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
  </link>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.065"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
  </link>

  <link name="upper_arm_link">
    <visual>
      <!--
        Arm extends from origin (shoulder_lift_joint) to elbow at -0.425 X.
        Cylinder Z aligned with X via pitch=90 deg; centred at midpoint.
      -->
      <origin xyz="-0.2125 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.054" length="0.425"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
  </link>

  <link name="forearm_link">
    <visual>
      <!--
        Arm extends from origin (elbow_joint) toward wrist_1 at -0.3922 X.
        Cylinder Z aligned with X via pitch=90 deg; centred at midpoint.
      -->
      <origin xyz="-0.1961 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.3922"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
  </link>

  <link name="wrist_1_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.047"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
  </link>

  <link name="wrist_2_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.047"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
  </link>

  <link name="wrist_3_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.07"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
  </link>

  <link name="ee_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <material name="ur_orange">
        <color rgba="1.0 0.5 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <!-- ======================================================== -->
  <!-- Joints                                                     -->
  <!-- ======================================================== -->

  <!--
    shoulder_pan_joint: base → shoulder
    shoulder_x=0, shoulder_y=0, shoulder_z=0.1625
    No frame rotation; rotates around world-Z (vertical pan).
  -->
  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.1625" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="150.0" velocity="3.1416"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <!--
    shoulder_lift_joint: shoulder → upper_arm
    upper_arm_x=0, upper_arm_y=0, upper_arm_z=0
    roll=90 deg rotates child frame so local-Z points horizontally;
    rotation around this local-Z = shoulder lift.
  -->
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="150.0" velocity="3.1416"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <!--
    elbow_joint: upper_arm → forearm
    forearm_x=-0.425, forearm_y=0, forearm_z=0
    No frame rotation; rotation around local-Z = elbow bend.
    Limits +-180 deg (physical constraint).
  -->
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="-0.425 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="150.0" velocity="3.1416"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <!--
    wrist_1_joint: forearm → wrist_1
    wrist_1_x=-0.3922, wrist_1_y=0, wrist_1_z=0.1333
    No frame rotation.
  -->
  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <origin xyz="-0.3922 0 0.1333" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="28.0" velocity="3.1416"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <!--
    wrist_2_joint: wrist_1 → wrist_2
    wrist_2_x=0, wrist_2_y=-0.0997, wrist_2_z=~0
    roll=90 deg; perpendicular wrist axis.
  -->
  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <origin xyz="0 -0.0997 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="28.0" velocity="3.1416"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <!--
    wrist_3_joint: wrist_2 → wrist_3
    wrist_3_x=0, wrist_3_y=0.0996, wrist_3_z=~0
    rpy = 90 deg roll + 180 deg pitch + 180 deg yaw (frame alignment).
  -->
  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_2_link"/>
    <child link="wrist_3_link"/>
    <origin xyz="0 0.0996 0" rpy="1.5708 3.14159 3.14159"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="28.0" velocity="3.1416"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <!--
    ee_fixed_joint: wrist_3 → ee_link (end-effector attachment point)
  -->
  <joint name="ee_fixed_joint" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>
